# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.sevalla.com

# Database - PostgreSQL
# Option A: Use DATABASE_URL (single connection string from many hosted providers)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# For SSL: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# DATABASE_URL=postgres://user:password@host.example.com:5432/dbname

# Option B: Individual variables (Sevalla auto-populates these when you attach a PostgreSQL database)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eshop_db
DB_USER=postgres
DB_PASSWORD=

# Email (optional)
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
